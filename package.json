{
  "name": "rosette-ecom",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "website"
  ],
  "scripts": {
    "build": "npm install && npm run build --workspace=website",
    "start": "node server/server.js",
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=website\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "nodemailer": "^8.0.4"
  }
}
